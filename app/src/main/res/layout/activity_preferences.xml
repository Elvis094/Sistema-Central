<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MIS PREFERENCIAS"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvGustosCargados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gustos seleccionados aparecerán aquí..."
        android:background="#EEEEEE"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etDescripcionPreferencias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Describe tus gustos aquí..."
        android:gravity="top"
        android:inputType="textMultiLine" />

    <Button
        android:id="@+id/btnGuardarPreferencias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GUARDAR PREFERENCIAS"
        android:layout_marginTop="24dp" />
</LinearLayout>
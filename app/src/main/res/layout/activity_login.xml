<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark"
    android:padding="24dp"
    android:paddingTop="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INICIAR SESIÓN"
        android:textColor="@color/neon_cyan"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etLoginCedula"
        style="@style/FuturisticEditText"
        android:hint="Cédula"
        android:inputType="number" />

    <EditText
        android:id="@+id/etLoginContrasena"
        style="@style/FuturisticEditText"
        android:hint="Contraseña"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/btnLoginIngresar"
        style="@style/FuturisticButton"
        android:backgroundTint="@color/neon_cyan"
        android:textColor="@color/bg_dark"
        android:text="INGRESAR"
        android:layout_marginTop="24dp" />
</LinearLayout>